<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.title %> - KravN</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/theme.js"></script>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
    <div class="brand">Krav<span>N</span></div>
    <div class="nav-links">
        <a href="/dashboard">Dashboard</a>
      <a class="muted" href="/feed">← Back to feed</a>
      </div>
    </div>
  </div>

  <div class="page">
    <div class="detail-header">
      <% if (post.poster_url && post.poster_url !== 'N/A') { %>
        <img class="detail-poster" src="<%= post.poster_url %>" alt="<%= post.movie_name %>">
      <% } else { %>
        <div class="post-poster-placeholder" style="width:110px; height:165px; font-size:2rem;">🎬</div>
      <% } %>
      <div class="detail-title-block">
        <div class="post-eyebrow">
          <span><%= post.movie_name %></span>
          <% if (post.imdb_rating && post.imdb_rating !== 'N/A') { %>
            <span class="post-rating">· IMDb <%= post.imdb_rating %></span>
          <% } %>
        </div>
        <h1><%= post.title %></h1>
        <p class="post-meta">Posted by <a href="/users/<%= post.username %>"><%= post.username %></a> · <%= new Date(post.created_at).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' }) %></p>
      </div>
    </div>

    <p class="detail-content"><%= post.content %></p>

    <div class="like-row">
      <form action="/posts/<%= post.id %>/like" method="POST">
        <button class="like-btn" type="submit">♥ Like (<%= likeCount %>)</button>
      </form>
    </div>

    <% if (likeCount > 0) { %>
  <p class="post-meta" style="margin-bottom: 1.5rem;">
    <a href="/posts/<%= post.id %>/likes">♥ <%= likeCount %> <%= likeCount === 1 ? 'person' : 'people' %> liked this</a>
  </p>
<% } %>
<div class="share-row">
  <span class="share-label">Share: </span>

  <button class="btn sm secondary" onclick="copyLink()" id="copy-btn">
    🔗 Copy Link
  </button>

 <a class="btn sm secondary"
    href="https://wa.me/?text=<%= encodeURIComponent(post.movie_name + ': ' + post.title + ' — ' + 'https://kravn.onrender.com/posts/' + post.id) %>"
    target="_blank" rel="noopener">
    WhatsApp
  </a>
</div>

<script>
function copyLink() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    const btn = document.getElementById('copy-btn');
    const original = btn.textContent;
    btn.textContent = '✓ Copied!';
    setTimeout(() => btn.textContent = original, 2000);
  });
}
</script>

        <% if (post.user_id === currentUserId) { %>
  <form action="/posts/<%= post.id %>/delete" method="POST" onsubmit="return confirm('Delete this discussion permanently?');">
    <button type="submit" class="secondary" style="color: var(--danger); border-color: var(--danger);">Delete</button>
  </form>
<% } %>
    <div class="sprocket-divider">
      <div class="holes"><span></span><span></span><span></span></div>
    </div>

    <h2 style="font-size: 1.2rem;">Comments</h2>

    <form class="comment-form" action="/posts/<%= post.id %>/comments" method="POST">
      <textarea name="content" placeholder="Add a comment..." required></textarea>
      <button type="submit">Comment</button>
    </form>

    <% if (comments.length === 0) { %>
      <p class="post-meta">No comments yet.</p>
    <% } %>

    <% comments.forEach(comment => { %>
  <div class="comment">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div class="comment-author">
        <a href="/users/<%= comment.username %>"><%= comment.username %></a>
      </div>
      <% if (comment.user_id === currentUserId) { %>
        <div style="display: flex; gap: 0.5rem;">
          <a href="/comments/<%= comment.id %>/edit" style="font-size: 0.8rem; color: var(--text-muted);">Edit</a>
          <form action="/comments/<%= comment.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Delete this comment?');">
            <button type="submit" style="background: none; border: none; color: var(--danger); font-size: 0.8rem; cursor: pointer; padding: 0;">Delete</button>
          </form>
        </div>
      <% } %>
    </div>
    <p class="comment-text"><%= comment.content %></p>
  </div>
<% }); %>
  </div>
</body>
</html>
