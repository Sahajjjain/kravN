<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notifications - KravN</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/theme.js"></script>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
      <div class="brand">Krav<span>N</span></div>
      <div class="nav-links">
        <a href="/feed">Feed</a>
        <a href="/dashboard">Dashboard</a>
        <a href="/posts/new">+ New</a>
        <a href="/notifications" class="active">🔔</a>
        <a class="muted" href="/about">About</a>
        <a class="muted" href="/logout">Logout</a>
      </div>
    </div>
  </div>

  <div class="page-narrow">
    <h1 style="font-size: 1.5rem; margin-bottom: var(--space-1);">Notifications</h1>
    <p class="auth-subtitle" style="margin-bottom: var(--space-6);">Who's been engaging with your posts.</p>

    <% if (notifications.length === 0) { %>
      <div class="empty-state">
        <p>No notifications yet. Post something to get the conversation going.</p>
      </div>
    <% } %>

    <% notifications.forEach(notification => { %>
      <div class="notification-card <%= notification.is_read ? '' : 'unread' %>">
        <div class="notification-icon">
          <%= notification.type === 'like' ? '♥' : '💬' %>
        </div>
        <div class="notification-body">
          <p class="notification-text">
            <a href="/users/<%= notification.actor_username %>">
              <strong><%= notification.actor_username %></strong>
            </a>
            <%= notification.type === 'like' ? 'liked' : 'commented on' %> your post
            <a href="/posts/<%= notification.post_id %>">
              <strong><%= notification.movie_name %>: <%= notification.post_title %></strong>
            </a>
          </p>
          <% if (notification.type === 'comment' && notification.comment_content) { %>
            <div class="notification-quote">
              "<%= notification.comment_content %>"
            </div>
          <% } %>
          <p class="notification-time">
            <%= new Date(notification.created_at).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' }) %>
          </p>
        </div>
      </div>
    <% }); %>
  </div>
</body>
</html>