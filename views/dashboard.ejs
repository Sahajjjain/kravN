<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - KravN</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
    <div class="brand">Krav<span>N</span></div>
    <div class="nav-links">
      <a class="muted" href="/feed">← Back to feed</a>
      </div>
    </div>
  </div>

  <div class="page">
    <h1 style="font-size: 1.5rem;">Your Discussions</h1>
    <p class="auth-subtitle">Everything you've posted, <%= username %>.</p>

    <% if (posts.length === 0) { %>
      <div class="empty-state">
        <p>You haven't posted anything yet.</p>
        <p><a href="/posts/new">Start your first discussion →</a></p>
      </div>
    <% } %>

    <% posts.forEach((post, i) => { %>
      <div class="post-card">
        <% if (post.poster_url && post.poster_url !== 'N/A') { %>
          <img class="post-poster" src="<%= post.poster_url %>" alt="<%= post.movie_name %>">
        <% } else { %>
          <div class="post-poster-placeholder">🎬</div>
        <% } %>
        <div class="post-body">
          <div class="post-eyebrow">
            <span><%= post.movie_name %></span>
          </div>
          <h3><a href="/posts/<%= post.id %>"><%= post.title %></a></h3>
          <p class="post-excerpt"><%= post.content %></p>
          <p class="post-meta">
            <span class="like-count"><%= post.like_count %></span> likes
            &nbsp;·&nbsp;
            <%= post.comment_count %> comments
          </p>
        </div>
      </div>
      <% if (i < posts.length - 1) { %>
        <div class="sprocket-divider">
          <div class="holes"><span></span><span></span><span></span></div>
        </div>
      <% } %>
    <% }); %>
  </div>
</body>
</html>
