<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feed - KravN</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
    <div class="brand">Krav<span>N</span></div>
    <div class="nav-links">
        <a href="/dashboard">Dashboard</a>
      <a href="/posts/new">+ New Discussion</a>
      <a class="muted" href="/about">About</a>
      <a class="muted" href="/logout">Logout</a>
    </div>
  </div>
  </div>

  <form class="search-form" id="search-form" action="/search" method="GET">
  <div class="movie-autocomplete" style="flex: 1; max-width: 480px;">
    <input
      type="text"
      name="q"
      id="search-input"
      placeholder="Search movies or shows..."
      autocomplete="off"
    >
    <div id="search-suggestions" class="suggestions-dropdown"></div>
  </div>
  <button type="submit">Search</button>
</form>
<script src="/js/movieAutocomplete.js"></script>
<script>
  attachMovieAutocomplete({
    inputId: 'search-input',
    dropdownId: 'search-suggestions',
    onSelect: async function(title) {
      try {
        const response = await fetch(`/api/movie-check?title=${encodeURIComponent(title)}`);
        const data = await response.json();
 
        if (data.exists) {
          window.location.href = `/search?q=${encodeURIComponent(title)}`;
        } else {
          window.location.href = `/posts/new?movie=${encodeURIComponent(title)}`;
        }
      } catch (err) {
        console.error('Movie check failed:', err);
        window.location.href = `/search?q=${encodeURIComponent(title)}`;
      }
    }
  });
</script>

  <div class="page">
    <p class="auth-subtitle" style="margin-bottom: 0;">Welcome, <%= username %></p>

    <% if (posts.length === 0) { %>
      <div class="empty-state">
        <p>No discussions yet. Be the first to start one.</p>
      </div>
    <% } %>

    <% posts.forEach((post, i) => { %>
      <div class="post-card">
        <% if (post.poster_url && post.poster_url !== 'N/A') { %>
          <img class="post-poster" src="<%= post.poster_url %>" alt="<%= post.movie_name %>">
        <% } else { %>
          <div class="post-poster-placeholder">🎬</div>
        <% } %>
        <div class="post-body">
          <div class="post-eyebrow">
            <span><%= post.movie_name %></span>
            <% if (post.imdb_rating && post.imdb_rating !== 'N/A') { %>
              <span class="post-rating">· IMDb <%= post.imdb_rating %></span>
            <% } %>
          </div>
          <h3><a href="/posts/<%= post.id %>"><%= post.title %></a></h3>
          <p class="post-excerpt"><%= post.content %></p>
          <p class="post-meta">Posted by <%= post.username %></p>
        </div>
      </div>
      <% if (i < posts.length - 1) { %>
        <div class="sprocket-divider">
          <div class="holes"><span></span><span></span><span></span></div>
        </div>
      <% } %>
    <% }); %>
  </div>
</body>
</html>
